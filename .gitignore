# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build

# env — never commit real keys
.env
.env.local
.env.*.local

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts
/coverage

# vercel
.vercel

# ── Personal / private data ──────────────────────────────────────────────────
# None of these should ever be committed — they contain PII and account data

# Bank statement PDFs + extracted JSON
/data/statements/

# LLM-generated analysis files (spending history)
/data/analyses/

# SQLite database (all transactions)
/data/*.db
/data/*.db-shm
/data/*.db-wal
/data/*.db-old
/data/*.db-shm.old
/data/*.db-wal.old

# App state files
/data/config.json
/data/merchant-tags.json
/data/recurring.json
/data/traces.jsonl

# Keep the data directory itself via .gitkeep
!/data/.gitkeep
