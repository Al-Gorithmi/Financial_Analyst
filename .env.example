# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — used for transaction tagging and insight generation
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────

# OpenAI API key — used as a fallback if the Anthropic call fails
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
